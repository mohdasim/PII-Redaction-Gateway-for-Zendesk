# =============================================================================
# PII Redaction Gateway for Zendesk — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Configuration ---
# Primary LLM provider: "claude", "openai", or "gemini"
LLM_PROVIDER=claude

# Set to "false" to disable LLM detection (regex-only mode, cheaper/faster)
LLM_ENABLED=true

# API keys for LLM providers (only the selected provider's key is required)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxx

# LLM confidence threshold (0.0-1.0). LLM-only detections below this are ignored.
LLM_CONFIDENCE_THRESHOLD=0.7

# --- Zendesk Configuration ---
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=bot@yourcompany.com
ZENDESK_API_TOKEN=xxxxxxxxxxxxxxxxxx

# Zendesk user ID of the bot/API user. Used for recursive loop prevention —
# webhook events triggered by this user are skipped automatically.
# Find this via Zendesk Admin > People > search for the bot user > ID in URL.
# If not set, fallback detection uses internal note pattern matching.
ZENDESK_BOT_USER_ID=

# --- Webhook Authentication ---
# Shared secret for HMAC-SHA256 webhook signature verification
WEBHOOK_SECRET=your-webhook-secret-here

# --- Redaction Configuration ---
# Style: "bracket" → [REDACTED-SSN], "mask" → ****
REDACTION_STYLE=bracket

# Comma-separated PII types to detect. Options:
# SSN, CREDIT_CARD, EMAIL, PHONE, PASSWORD, PHI, ADDRESS, NAME, DATE_OF_BIRTH
ENABLED_PII_TYPES=SSN,CREDIT_CARD,EMAIL,PHONE,PASSWORD,PHI,ADDRESS,NAME,DATE_OF_BIRTH

# --- AWS Configuration ---
# S3 bucket for audit logs (set by Terraform, override for local testing)
AUDIT_S3_BUCKET=pii-redaction-audit-bucket

# --- Logging ---
LOG_LEVEL=INFO
